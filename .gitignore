# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build
/dist

# astro
.astro/

# playwright
.playwright-mcp/
playwright-report/
test-results/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local config (contains secrets/personal settings)
.mcp.json
.claude/settings.local.json

.vercel

# Additional secret patterns
credentials.json
service-account*.json
*.key
*.p12

# Python artefacts (if any local scripts)
__pycache__/
*.pyc
.venv/
venv/

# Scratch / test data
scratch/
tmp/
*.log
